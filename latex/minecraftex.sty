\DeclareTextFontCommand{\galactic}{\mctex@galacticfont}
\let\mctex@normalmathbf\mathbf
\let\mctex@normalmathit\mathit
\let\mctex@normalsymbf\symbf
\let\mctex@normalsymbfit\symbfit
\newcommand{\mctex@galacticmathalphabet}[1]{#1}
\newcommand{\galacticmode}{%
  \setmainfont{\mctex@fontfile}[\mctex@galacticfeatures]%
  \setsansfont{\mctex@fontfile}[\mctex@galacticfeatures]%
  \setmonofont{\mctex@fontfile}[\mctex@galacticfeatures]%
  \mctex@galacticmathcodes%
  \let\mathbf\mctex@galacticmathalphabet%
  \let\mathit\mctex@galacticmathalphabet%
  \let\symbf\mctex@galacticmathalphabet%
  \let\symbfit\mctex@galacticmathalphabet%
}
\newcommand{\normalmode}{%
  \setmainfont{\mctex@fontfile}[\mctex@textfeatures]%
  \setsansfont{\mctex@fontfile}[\mctex@textfeatures]%
  \setmonofont{\mctex@fontfile}[\mctex@textfeatures]%
  \mctex@normalmathcodes%
  \let\mathbf\mctex@normalmathbf%
  \let\mathit\mctex@normalmathit%
  \let\symbf\mctex@normalsymbf%
  \let\symbfit\mctex@normalsymbfit%
}

% Table support stays on LaTeX's standard tabular/array path, but snaps the
% visible rules and padding to the same blocky rhythm as the font. One font
% pixel is 0.1em on MinecrafTeX's grid, so table rules use that thickness
% instead of LaTeX's usual hairline rule.
\newcommand{\minecraftextablesetup}{%
  \setlength{\arrayrulewidth}{0.1em}%
  \setlength{\tabcolsep}{4pt}%
  \setlength{\extrarowheight}{0.35em}%
  \renewcommand{\arraystretch}{1.28}%
}
\newenvironment{mctextable}[1]
  {\begingroup\minecraftextablesetup\begin{tabular}{#1}}
  {\end{tabular}\endgroup}

