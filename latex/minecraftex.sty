%% minecraftex.sty -- typeset math in Minecraft pixel style
%% Part of MinecrafTeX. MIT-licensed (see LICENSE); the loaded font is OFL 1.1.
%%
%% Requires a Unicode TeX engine: compile with lualatex or xelatex.
%%
%% Usage:
%%     \usepackage{minecraftex}                         % proportional spacing
%%     \usepackage[scale=1.4]{minecraftex}              % scale the pixel font up
%%     \usepackage[spacing=mono]{minecraftex}           % fixed-cell spacing
%%     \galactic{Hello World.}                          % Standard Galactic text
%%     \galacticmode ... \normalmode                    % document-level switch
%%
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{minecraftex}[2026/06/16 v0.1 MinecrafTeX pixel math]

\RequirePackage{kvoptions}
\SetupKeyvalOptions{family=mctex,prefix=mctex@}
% Font scale (keep an integer-ish multiple to preserve crisp pixels).
\DeclareStringOption[1.0]{scale}
% Spacing mode: proportional (natural text/math spacing) or mono (fixed cell).
\DeclareStringOption[proportional]{spacing}
% Path to the directory holding the MinecrafTeX font files.
\DeclareStringOption[../font/dist/]{fontpath}
\ProcessKeyvalOptions*

\newcommand{\mctex@fontfile}{MinecrafTeX-Math-Proportional.ttf}
\newcommand{\mctex@boldfontfile}{MinecrafTeX-Math-Proportional-Bold.ttf}
\newcommand{\mctex@italicfontfile}{MinecrafTeX-Math-Proportional-Italic.ttf}
\newcommand{\mctex@bolditalicfontfile}{MinecrafTeX-Math-Proportional-BoldItalic.ttf}
\edef\mctex@monospacing{mono}
\edef\mctex@fixedspacing{monospace}
\ifx\mctex@spacing\mctex@monospacing
  \renewcommand{\mctex@fontfile}{MinecrafTeX-Math.ttf}
  \renewcommand{\mctex@boldfontfile}{MinecrafTeX-Math.ttf}
  \renewcommand{\mctex@italicfontfile}{MinecrafTeX-Math.ttf}
  \renewcommand{\mctex@bolditalicfontfile}{MinecrafTeX-Math.ttf}
\fi
\ifx\mctex@spacing\mctex@fixedspacing
  \renewcommand{\mctex@fontfile}{MinecrafTeX-Math.ttf}
  \renewcommand{\mctex@boldfontfile}{MinecrafTeX-Math.ttf}
  \renewcommand{\mctex@italicfontfile}{MinecrafTeX-Math.ttf}
  \renewcommand{\mctex@bolditalicfontfile}{MinecrafTeX-Math.ttf}
\fi

\newcommand{\mctex@textfeatures}{%
  Path=\mctex@fontpath ,
  Scale=\mctex@scale ,
  BoldFont=\mctex@boldfontfile ,
  ItalicFont=\mctex@italicfontfile ,
  BoldItalicFont=\mctex@bolditalicfontfile ,
}
\newcommand{\mctex@galacticfeatures}{%
  Path=\mctex@fontpath ,
  Scale=\mctex@scale ,
  BoldFont=\mctex@boldfontfile ,
  ItalicFont=\mctex@italicfontfile ,
  BoldItalicFont=\mctex@bolditalicfontfile ,
  RawFeature=+ss01 ,
}

\RequirePackage{fontspec}
\RequirePackage{unicode-math}
\RequirePackage{array}

% Load the pixel math font as BOTH the math font and the upright text font so
% that text and equations match.
\setmathfont{\mctex@fontfile}[
  Path=\mctex@fontpath ,
  Scale=\mctex@scale ,
]
\setmathfont{\mctex@boldfontfile}[
  Path=\mctex@fontpath ,
  Scale=\mctex@scale ,
  version=bold,
]
\setmainfont{\mctex@fontfile}[\mctex@textfeatures]
\setsansfont{\mctex@fontfile}[\mctex@textfeatures]
\setmonofont{\mctex@fontfile}[\mctex@textfeatures]
\newfontfamily\mctex@galacticfont{\mctex@fontfile}[\mctex@galacticfeatures]

